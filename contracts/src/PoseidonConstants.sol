    /// @dev MDS circulant row (small constants, inline)
    function mdsCirc(uint256 i) internal pure returns (uint256) {
        assembly {
            switch i
            case 0  { mstore(0, 17) }
            case 1  { mstore(0, 15) }
            case 2  { mstore(0, 41) }
            case 3  { mstore(0, 16) }
            case 4  { mstore(0, 2) }
            case 5  { mstore(0, 28) }
            case 6  { mstore(0, 13) }
            case 7  { mstore(0, 13) }
            case 8  { mstore(0, 39) }
            case 9  { mstore(0, 18) }
            case 10 { mstore(0, 34) }
            case 11 { mstore(0, 20) }
            return(0, 32)
        }
    }

    /// @dev MDS diagonal (only element 0 is non-zero)
    function mdsDiag(uint256 i) internal pure returns (uint256) {
        if (i == 0) return 8;
        return 0;
    }

